# ============================================================
# Charging Station Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ============================================================

# Active Profile (dev | prod)
# SPRING_PROFILES_ACTIVE=dev

# ---- PostgreSQL ----
DB_HOST=localhost
DB_PORT=30001
DB_NAME=charging_station
DB_USERNAME=cs_user
DB_PASSWORD=dev_password_123

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=30002
# REDIS_PASSWORD=

# ---- JWT ----
JWT_SECRET=dev-secret-key-not-for-production-use-32chars!!

# ---- Payment Gateways ----
PAYMENT_HMAC_SECRET=default-hmac-secret-change-in-production
WECHAT_API_KEY=wechat-default-key
ALIPAY_API_KEY=alipay-default-key